# Base URL of the Spring Boot REST API.
# In the legacy AngularJS app this was the hardcoded `config.url`.
# Point this at your backend; during dev the Vite proxy maps /api -> this target.
VITE_API_BASE_URL=/api/
# Backend runs on 8081 (port 8080 is taken by XAMPP/Apache on this machine).
VITE_API_TARGET=http://localhost:8081

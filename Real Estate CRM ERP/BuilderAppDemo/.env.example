# ============================================================================
# Local environment for the Real Estate CRM backend (NOT committed to git).
# Loaded by Spring Boot via spring.config.import (see application.yml).
# Real OS environment variables (e.g. on Render) always take precedence.
# ============================================================================

# --- Database (Aiven MySQL) -------------------------------------------------
DB_HOST=YOUR_MYSQL_HOST
DB_PORT=3306
DB_USER=YOUR_DB_USER
# Put your real Aiven password here (this file is gitignored):
DB_PASSWORD=YOUR_DB_PASSWORD
DB_NAME=bcs_angular_uat
DB_SSL=true

# --- Auth -------------------------------------------------------------------
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars

# --- CORS (comma-separated origins allowed to call the API) ------------------
CORS_ORIGINS=http://localhost:5173

# --- Email (SMTP) — used for demand letters / forgot password ----------------
# Defaults preserve the legacy account; override with your own.
#MAIL_HOST=smtpout.secureserver.net
#MAIL_USERNAME=
#MAIL_PASSWORD=

# --- SMS (Textlocal) ----------------------------------------------------------
#TEXTLOCAL_API_KEY=

# --- File storage / legacy constants -----------------------------------------
#FILE_SAVE_LOCATION=C:\Users\ysmvts\sms_images\BuilderAppUat\
#SERVER_IMG_LOCATION=http://localhost:8081/images/BuilderAppUat/
